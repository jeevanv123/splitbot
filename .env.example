# Required
TELEGRAM_BOT_TOKEN=        # from @BotFather

# LLM provider — pick one and fill its section.
LLM_PROVIDER=anthropic     # "anthropic" or "bedrock"

# --- Anthropic API (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=

# --- AWS Bedrock (used when LLM_PROVIDER=bedrock) ---
# Auth uses the AWS default credential chain — set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY here,
# or use ~/.aws/credentials, or rely on an IAM role.
AWS_REGION=

# Optional — override the default Claude model id for your provider.
# Anthropic default: claude-sonnet-4-6
# Bedrock  default: anthropic.claude-sonnet-4-5-20250929-v1:0
CLAUDE_MODEL=

# Optional
DATABASE_URL=              # blank → SQLite at ./data/splitbot.db
SENTRY_DSN=
LOG_LEVEL=info
